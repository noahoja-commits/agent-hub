# Agent Hub — Environment Variables
# Copy to .env and fill in your values

# LLM provider (litellm format)
LLM_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=sk-...

# Gmail API (for Email Agent)
# Get credentials: https://console.cloud.google.com/apis/credentials
# Create OAuth2 client ID (Desktop app), then get refresh token
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# Telegram Bot (for phone commands)
# Create bot: message @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=...

# GitHub (for Fixit Agent)
GITHUB_TOKEN=ghp_...

# Database
AGENT_HUB_DB=agent_hub.db

# WebSocket / Local Agent
AGENT_HUB_TOKEN=change-me
AGENT_ID=pc-mymachine-01

# Scheduler
SCHEDULER_ENABLED=true
DAILY_BRIEFING_TIME=08:00

# Server
PORT=5679
BASE_URL=https://agent-hub.railway.app
