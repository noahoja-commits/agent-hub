# Agent Hub — Environment Variables
# Copy to .env and fill in your values

# LLM provider (litellm format)
LLM_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=sk-...

# Lark / Feishu Mail API (for Email Agent)
LARK_APP_ID=cli_...
LARK_APP_SECRET=...
LARK_USER_ACCESS_TOKEN=u-...       # User access token for mail operations
# OR
LARK_TENANT_ACCESS_TOKEN=t-...     # Tenant access token (read-only fallback)

# GitHub (for Fixit Agent)
GITHUB_TOKEN=ghp_...

# Database
AGENT_HUB_DB=agent_hub.db

# WebSocket / Local Agent
AGENT_HUB_TOKEN=change-me          # Shared secret for local agent auth
AGENT_ID=pc-mymachine-01           # Optional: override auto-generated agent ID

# Scheduler
SCHEDULER_ENABLED=true
DAILY_BRIEFING_TIME=08:00          # HH:MM UTC for daily briefing

# Server
PORT=5679
